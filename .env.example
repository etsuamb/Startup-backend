# Optional Compose overrides. backend/.env remains the source for application secrets.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=finalpro
POSTGRES_DB=connect_startup
POSTGRES_PORT=5432
BACKEND_PORT=5001
FRONTEND_PORT=3000
FRONTEND_URL=https://startup-connect-ethiopia-frontend.onrender.com
# Local dev against deployed backend:
BACKEND_URL=https://startup-connect-ethiopia.onrender.com
NEXT_PUBLIC_SOCKET_URL=https://startup-connect-ethiopia.onrender.com
# WebRTC defaults to Google's public STUN server. Configure TURN for reliable calls across restrictive networks.
NEXT_PUBLIC_STUN_URL=stun:stun.l.google.com:19302
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
# Local full stack:
# BACKEND_URL=http://localhost:5001
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5001
NEXT_PUBLIC_CHAT_E2E_SECRET=

# AI providers
# Groq is recommended for more free API calls. Use these on the backend host.
GROQ_API_KEY=
AI_MENTOR_PROVIDER=groq
AI_REVIEW_PROVIDER=groq
GROQ_MODEL=llama-3.1-8b-instant
GROQ_REVIEW_MODEL=llama-3.1-8b-instant

# Optional fallbacks
GEMINI_API_KEY=
OPENAI_API_KEY=

# Render backend service env
# DB_* values are auto-wired by render.yaml when using the Blueprint.
DB_HOST=
DB_PORT=5432
DB_NAME=connect_startup
DB_USER=
DB_PASSWORD=
DB_SSL=true
JWT_SECRET=
GOOGLE_CLIENT_ID=
CORS_ORIGIN=
BREVO_HTTP_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=StartupConnect
CHAPA_PUBLIC_KEY=
CHAPA_SECRET_KEY=
CHAPA_RETURN_URL=
CHAPA_CALLBACK_URL=

# Render frontend service env
# BACKEND_HOSTPORT is auto-wired by render.yaml for server-side rewrites.
BACKEND_HOSTPORT=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_API_BASE=
