# Brevo email for Render/production — use HTTP API key (works everywhere)
# 1. Brevo -> Settings -> Senders -> verify your Gmail
# 2. Brevo -> Settings -> SMTP & API -> API Keys -> copy xkeysib- key
BREVO_HTTP_API_KEY=
BREVO_FROM_EMAIL=etsubgirma0312@gmail.com
BREVO_FROM_NAME=StartupConnect

# Optional local/dev SMTP (xsmtpsib-) — often blocked on Render IPs
BREVO_SMTP_USER=ad1645001@smtp-brevo.com
BREVO_SMTP_KEY=

# Resend fallback
RESEND_API_KEY=
RESEND_FROM_EMAIL=StartupConnect <onboarding@resend.dev>

# Generic SMTP fallback. On Render, set RENDER_ALLOW_SMTP=true to enable it.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
RENDER_ALLOW_SMTP=false
