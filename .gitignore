# ============================================================
#  ROOT .gitignore — Startup Connect Ethiopia Monorepo
#  Covers: Node.js/Express backend · Next.js frontend · Flutter mobile
# ============================================================

# ------------------------------------------------------------
# Environment & Secrets  (NEVER commit these)
# ------------------------------------------------------------
.env
.env.*
!.env.example          # keep the example template committed
*.pem
*.key
*.p12
*.pfx
secrets/

# ------------------------------------------------------------
# Node.js (backend & frontend)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnp.*
package-lock.json      # optional: remove this line if you want to commit lock files

# ------------------------------------------------------------
# Next.js (frontend)
# ------------------------------------------------------------
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ------------------------------------------------------------
# Build & Dist outputs
# ------------------------------------------------------------
dist/
build/
out/

# ------------------------------------------------------------
# Uploads & User-generated content
# ------------------------------------------------------------
backend/uploads/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
logs/
*.log
backend/logs/

# ------------------------------------------------------------
# Test coverage
# ------------------------------------------------------------
coverage/
.nyc_output/

# ------------------------------------------------------------
# Flutter / Dart / Mobile
# ------------------------------------------------------------
Mobile/.dart_tool/
Mobile/.flutter-plugins
Mobile/.flutter-plugins-dependencies
Mobile/.pub-cache/
Mobile/.pub/
Mobile/build/
Mobile/coverage/
**/doc/api/
**/ios/Flutter/.last_build_id
app.*.symbols
app.*.map.json
Mobile/android/app/debug
Mobile/android/app/profile
Mobile/android/app/release

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
.docker/

# ------------------------------------------------------------
# Database / SQL dumps
# ------------------------------------------------------------
*.sql.bak
backups/
backend/backups/

# ------------------------------------------------------------
# OS & Editor artefacts
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.iml
*.ipr
*.iws
*.swp
*.swo
.atom/
.history/
.svn/
.swiftpm/
migrate_working_dir/

# ------------------------------------------------------------
# Miscellaneous compiled / temporary files
# ------------------------------------------------------------
*.class
*.pyc
*.pyo
__pycache__/
*.tmp
*.bak
*.orig
